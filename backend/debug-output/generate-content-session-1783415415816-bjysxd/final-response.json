{
  "activities": [
    {
      "name": "समूह चर्चा: पाठ की पहचान",
      "instructions": [
        "छात्रों को 4-5 लोगों के समूहों में बांटें।",
        "प्रत्येक समूह को एक छोटा गद्यांश (100 शब्द) दें।",
        "समूह को निर्देश दें कि वे पाठ का मुख्य विचार (Main Idea) और दो सहायक बिंदु (Supporting Points) पहचानें।",
        "प्रत्येक समूह अपने निष्कर्षों को कक्षा के सामने प्रस्तुत करे।"
      ],
      "durationMinutes": 10
    },
    {
      "name": "व्यावहारिक अभ्यास: सारांश लेखन",
      "instructions": [
        "शिक्षक एक नया गद्यांश बोर्ड पर लिखें या प्रोजेक्टर पर दिखाएं।",
        "छात्रों को 15 मिनट का समय दें ताकि वे उसका सारांश (Summary) तैयार कर सकें।",
        "निर्देश दें कि सारांश में केवल मुख्य बिंदु हों और कोई भी नया विचार न जोड़ा जाए।",
        "छात्र अपने उत्तरों को एक-दूसरे के साथ साझा करें और शिक्षक की प्रतिक्रिया सुनें।"
      ],
      "durationMinutes": 15
    },
    {
      "name": "मूल्यांकन: त्वरित परीक्षण",
      "instructions": [
        "छात्रों को एक छोटा मूल्यांकन प्रश्नपत्र (MCQ और लघु उत्तर) दें।",
        "प्रश्नों का उत्तर देने के लिए 15 मिनट का समय दें।",
        "समय समाप्त होने पर उत्तर पत्र एकत्र करें।"
      ],
      "durationMinutes": 15
    }
  ],
