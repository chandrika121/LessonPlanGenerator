      "answerKey": {
        "items": [
          {
            "questionId": "q1",
            "sectionId": "section-theory-max-marks-70-time-3-hrs",
            "sectionTitle": "Theory: Max Marks 70, Time 3 hrs",
            "answer": "B. Charge is quantized and exists in discrete packets.",
